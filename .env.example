# Copy this file to .env and fill in the values
# Do NOT commit .env to source control

# Disable CRA host check (required for dev server on non-localhost)
DANGEROUSLY_DISABLE_HOST_CHECK=true

# Backend API base URL (no trailing slash)
# Staging:    https://api.staging.integratedtech.ca
# Production: https://api.integratedtech.ca
REACT_APP_BACKEND_URL=https://api.staging.integratedtech.ca
